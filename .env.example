# =============================================================================
# Personal Blog CMS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before `docker compose up`.
# NEVER commit .env to git (it's in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 17)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=blog_db
DB_USER=blog_user
DB_PASSWORD=change_me_to_a_long_random_string_at_least_32_chars

# PostgreSQL tuning (8 GB RAM host)
POSTGRES_SHARED_BUFFERS=1GB
POSTGRES_EFFECTIVE_CACHE_SIZE=4GB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_MAX_CONNECTIONS=50

# -----------------------------------------------------------------------------
# Backend (Spring Boot)
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xms512m -Xmx1536m -XX:+UseG1GC

# Backend's own public base URL — used by the API for absolute media URLs,
# password-reset links, etc. In prod set to your real domain.
# Dev: http://localhost:8080   Prod: https://news.luuhailong.com
APP_BASE_URL=http://localhost
UPLOAD_DIR=/data/uploads

# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET=change_me_long_random_secret_at_least_64_chars_base64
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Cookie security (set to true in production with HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# -----------------------------------------------------------------------------
# Admin frontend (React/Vite, served at /admin)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api

# -----------------------------------------------------------------------------
# Public site (Next.js — service `public-web`, served at /)
# -----------------------------------------------------------------------------
# Public canonical domain — baked into the Next build (canonical/OG/sitemap).
# MUST be the real public domain in prod (NOT the backend APP_BASE_URL).
# Dev: http://localhost:8088   Prod: https://news.luuhailong.com
PUBLIC_SITE_URL=https://news.luuhailong.com
# (BLOG_API_URL — Next→backend, server-side — is hardcoded to http://blog-api:8080
#  in docker-compose; no need to set it here.)

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
