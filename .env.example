# =============================================================================
# Personal Blog CMS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before `docker compose up`.
# NEVER commit .env to git (it's in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 17)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=blog_db
DB_USER=blog_user
DB_PASSWORD=change_me_to_a_long_random_string_at_least_32_chars

# PostgreSQL tuning (8 GB RAM host)
POSTGRES_SHARED_BUFFERS=1GB
POSTGRES_EFFECTIVE_CACHE_SIZE=4GB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_MAX_CONNECTIONS=50

# -----------------------------------------------------------------------------
# Backend (Spring Boot)
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=-Xms512m -Xmx1536m -XX:+UseG1GC

# Public base URL (used for canonical URLs, OG tags, sitemap)
APP_BASE_URL=http://localhost
UPLOAD_DIR=/data/uploads

# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET=change_me_long_random_secret_at_least_64_chars_base64
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Cookie security (set to true in production with HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# -----------------------------------------------------------------------------
# Admin frontend (React/Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api

# -----------------------------------------------------------------------------
# Public frontend (React/Vite)
# -----------------------------------------------------------------------------
VITE_PUBLIC_API_BASE_URL=/api
VITE_PUBLIC_BASE_URL=http://localhost

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
